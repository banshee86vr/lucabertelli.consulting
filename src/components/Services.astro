---
import ServiceIcon from "./ServiceIcon.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import type { ServiceIconName } from "../types/service-icons";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const services: {
  title: string;
  text: string;
  icon: ServiceIconName;
}[] = [
  {
    title: t("index.services.1.title"),
    text: t("index.services.1.text"),
    icon: "clipboard-list",
  },
  {
    title: t("index.services.2.title"),
    text: t("index.services.2.text"),
    icon: "cloud-upload",
  },
  {
    title: t("index.services.3.title"),
    text: t("index.services.3.text"),
    icon: "workflow",
  },
  {
    title: t("index.services.4.title"),
    text: t("index.services.4.text"),
    icon: "graduation-cap",
  },
  {
    title: t("index.services.5.title"),
    text: t("index.services.5.text"),
    icon: "bot",
  },
];
---

<section class="lb-ins__area pb-100">
  <div class="container">
    <div class="lb-inp__project-sec-title-wrap">
      <h2 class="lb-inp__project-title">
        {t("index.services.title")}
      </h2>
    </div>

    <div class="services-grid" style="margin-top: 60px;">
      {services.map((service) => (
        <article class="service-card">
          <div class="service-card__icon">
            <ServiceIcon name={service.icon} />
          </div>
          <h3 class="service-card__title">{service.title}</h3>
          <p class="service-card__text">{service.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services-grid {
    display: grid;
    gap: 24px;
  }

  /* Desktop: 3 + 2 - avoids a lone card on a second row */
  @media (min-width: 992px) {
    .services-grid {
      grid-template-columns: repeat(6, 1fr);
    }

    .service-card:nth-child(1) {
      grid-column: 1 / 3;
    }
    .service-card:nth-child(2) {
      grid-column: 3 / 5;
    }
    .service-card:nth-child(3) {
      grid-column: 5 / 7;
    }
    .service-card:nth-child(4) {
      grid-column: 2 / 4;
    }
    .service-card:nth-child(5) {
      grid-column: 4 / 6;
    }
  }

  .service-card {
    display: flex;
    flex-direction: column;
    padding: 32px 28px;
    border-radius: 12px;
    background: linear-gradient(
      168deg,
      var(--black-4) 0%,
      var(--black-3) 100%
    );
    border: 1px solid var(--black-6);
    transition: none;
  }

  .service-card:hover {
    border-color: var(--primary);
    transform: none;
  }

  .service-card__icon {
    width: 72px;
    height: 72px;
    margin-bottom: 24px;
    flex-shrink: 0;
    color: var(--primary);
  }

  .service-card__icon :global(.service-icon__svg) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .service-card:hover .service-card__icon {
    color: var(--primary);
    filter: brightness(1.08);
  }

  :global(.light) .service-card__icon {
    color: var(--secondary);
  }

  :global(.light) .service-card:hover .service-card__icon {
    color: var(--secondary);
    filter: none;
  }

  .service-card__title {
    font-size: 22px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--white);
    margin-bottom: 16px;
    min-height: 3.9em;
  }

  .service-card__text {
    font-size: 15px;
    font-weight: 400;
    line-height: 1.6;
    color: var(--gray-4);
    margin: 0;
    padding: 0;
  }

  :global(.light) .service-card {
    background: linear-gradient(
      168deg,
      var(--white-3) 0%,
      rgba(255, 255, 255, 0) 100%
    );
    border-color: var(--gray-13);
  }

  :global(.light) .service-card:hover {
    background-color: var(--white-3);
    border-color: var(--secondary);
  }

  :global(.light) .service-card__title {
    color: var(--black-2);
  }

  :global(.light) .service-card__text {
    color: var(--gray);
  }

  @media (max-width: 1199px) {
    .service-card {
      padding: 28px 24px;
    }

    .service-card__title {
      font-size: 20px;
    }
  }

  @media (max-width: 991px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }

    .service-card:nth-child(n) {
      grid-column: auto;
    }

    .service-card__title {
      min-height: unset;
    }
  }

  @media (max-width: 575px) {
    .services-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .service-card {
      padding: 24px 20px;
    }
  }
</style>

---
import BaseLayout from "./Common.astro";
import Tickets from "../components/Tickets.astro";

import { getBlogPosts } from "../content/config";
import type { CollectionEntry } from "astro:content";

import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { absoluteUrl } from "../utils/seo";
import { buildBlogPosting } from "../utils/jsonLd";
import type { UiLang } from "../utils/seo";

type BlogData = CollectionEntry<"blog">["data"];
type Props = BlogData & { blogSlug: string };

const { title, subtitle, date, category, image, tags, lang, blogSlug } =
	Astro.props as Props;

const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);

const canonicalUrl = absoluteUrl(`/${lang}/blog/${blogSlug}`);
const blogPosting = buildBlogPosting({
	headline: title,
	description: subtitle,
	datePublished: date,
	image,
	url: canonicalUrl,
	inLanguage: lang as UiLang,
	keywords: tags,
});

const heroWidths = [480, 768, 1200];
const cardWidths = [320, 480, 640];
const appendImageParams = (url: string, params: string) =>
	`${url}${url.includes("?") ? "&" : "?"}${params}`;
const buildSrcSet = (url: string, widths: number[], format?: "webp") =>
	widths
		.map((width) => {
			const query = format ? `format=${format}&w=${width}` : `w=${width}`;
			return `${appendImageParams(url, query)} ${width}w`;
		})
		.join(", ");

const blogEntries = (await getBlogPosts())
	.filter((blogEntry) => blogEntry.blog_slug !== blogSlug)
	.filter(function (blogEntry) {
		return blogEntry.data.tags.some((element: string) => {
			return tags.indexOf(element) !== -1;
		});
	})
	.filter((blogEntry) => blogEntry.data.lang == currentLang)
	.sort(
		(a, b) =>
			b.data.date.valueOf() - a.data.date.valueOf(),
	)
	.slice(0, 4);
---

<BaseLayout
	title={`${title} | Luca Bertelli`}
	description={subtitle}
	ogImage={image}
	ogType="article"
	canonical={canonicalUrl}
	articlePublishedTime={date.toISOString()}
	articleModifiedTime={date.toISOString()}
	articleSection={category}
	articleTags={tags}
	jsonLdExtra={[blogPosting]}
>
  <!-- Blog Details section end -->
  <section class="blog__details__area pt-80 pb-30">
    <div class="container">
      <div class="row">
        <div class="col-xxl-12">
          <div class="blog__details-top cf_parallax_image">
            <picture>
              <source
                type="image/webp"
                srcset={buildSrcSet(image, heroWidths, "webp")}
                sizes="(max-width: 991px) 100vw, 1200px"
              />
              <source
                srcset={buildSrcSet(image, heroWidths)}
                sizes="(max-width: 991px) 100vw, 1200px"
              />
              <img
                class="blog__details-hero-img"
                src={appendImageParams(image, "w=768")}
                srcset={buildSrcSet(image, heroWidths)}
                sizes="(max-width: 991px) 100vw, 1200px"
                alt={title}
                width="1200"
                height="675"
                fetchpriority="high"
                decoding="async"
                data-speed="0.9"
              />
            </picture>
          </div>

          <div class="blog__details-wrap">
            <div class="blog__details-info">
              <ul class="blog__meta">
                <li>
                  <span class="blog__meta-label">{t("post.header.category")}</span>
                  <span class="blog__meta-value">{category}</span>
                </li>
                <li>
                  <span class="blog__meta-label">{t("post.header.language")}</span>
                  <span class="blog__meta-value">{lang.toUpperCase()}</span>
                </li>
                <li>
                  <span class="blog__meta-label">{t("post.header.date")}</span>
                  <time
                    class="blog__meta-value"
                    datetime={date.toISOString()}
                  >
                    {
                      date.toLocaleDateString(lang, {
                        year: "numeric",
                        month: "short",
                        day: "numeric",
                      })
                    }
                  </time>
                </li>
              </ul>
              <h1 class="blog__details_title">
                {title}
              </h1>
              <p class="blog__details_subtitle">{subtitle}</p>
            </div>

            <div class="blog__details">
              <slot />
            </div>

            <div class="blog__tag">
              <p class="blog__tag-title">{t('post.tagsLabel')} /</p>
              <ul class="blog__tag-list">
                {
                  tags.map((tag, i) => (
                    <li>
                      <a href={`/${lang}/blog?tag=${encodeURIComponent(tag)}`}>{tag}</a>
                      {i < tags.length - 1 ? <span class="blog__tag-sep" aria-hidden="true"> / </span> : null}
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- Blog Details section start -->

  <!-- Recent Blog section start -->
  <section class="blog__related pb-120">
    <div class="container">
      <div class="row">
        <div class="col-xxl-12">
          <div class="sec-title-wrapper pt-120">
            <h2 class="sec-sub-title mb-20">{t('post.sectionLabel')}</h2>
            <h3 class="sec-title">{t('post.related.title')}</h3>
          </div>
        </div>
      </div>

      <div class="row">
        <div class="col-xxl-12">
          <div class="blog__related-grid">
            {
              blogEntries.map((post) => (
                <article class="lb-blog__item blog-img-zoom">
                  <div class="thumb">
                    <a href={`/${lang}/blog/${post.blog_slug}`}>
                      <picture>
                        <source
                          type="image/webp"
                          srcset={buildSrcSet(post.data.image, cardWidths, "webp")}
                          sizes="(max-width: 767px) 100vw, 25vw"
                        />
                        <source
                          srcset={buildSrcSet(post.data.image, cardWidths)}
                          sizes="(max-width: 767px) 100vw, 25vw"
                        />
                        <img
                          src={appendImageParams(post.data.image, "w=480")}
                          srcset={buildSrcSet(post.data.image, cardWidths)}
                          sizes="(max-width: 767px) 100vw, 25vw"
                          alt={post.data.title}
                          width={800}
                          height={450}
                          loading="lazy"
                          decoding="async"
                        />
                      </picture>
                    </a>
                  </div>
                  <ul class="lb-blog__meta">
                    <li>
                      <span>
                        {post.data.date.toLocaleString(lang === "it" ? "it-IT" : "en-US", {
                          year: "numeric",
                          month: "short",
                          day: "numeric",
                        })}
                      </span>
                    </li>
                  </ul>
                  <a href={`/${lang}/blog/${post.blog_slug}`}>
                    <h3 class="lb-blog__title">{post.data.title}</h3>
                  </a>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- Recent Blog section end -->

  <Tickets />
</BaseLayout>

<style>
  .blog__details-info :global(ul.blog__meta) {
    gap: 2rem;
    padding-bottom: 2.5rem;
    flex-wrap: wrap;
  }
  .blog__details-info :global(ul.blog__meta li) {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.2rem;
    min-width: 0;
  }
  .blog__details-info :global(ul.blog__meta li::after) {
    inset-inline-end: -1rem;
  }
  .blog__details-info :global(.blog__meta-label) {
    display: block;
    font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--black-9);
  }
  .blog__details-info :global(.blog__meta-value),
  .blog__details-info :global(time.blog__meta-value) {
    display: block;
    font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--white);
  }
  :global(.light) .blog__details-info :global(.blog__meta-value),
  :global(.light) .blog__details-info :global(time.blog__meta-value) {
    color: var(--black-2);
  }
  .blog__details-info :global(.blog__details_title) {
    padding-bottom: 0.75rem;
  }
  .blog__details_subtitle {
    font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
    font-size: 1.125rem;
    line-height: 1.6;
    margin-top: 0;
    margin-bottom: 0;
    font-weight: 500;
    opacity: 0.85;
    color: var(--black-9);
  }
  .blog__details-hero-img {
    display: block;
    width: 100%;
    max-height: 400px;
    aspect-ratio: 16 / 9;
    height: auto;
    object-fit: cover;
  }
  @media only screen and (max-width: 767px) {
    .blog__details-info :global(ul.blog__meta) {
      gap: 1.25rem 1.75rem;
    }
  }
</style>

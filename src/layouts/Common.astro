---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieBanner from "../components/CookieBanner.astro";

import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { SEO } from "astro-seo";
import { absoluteUrl, alternatesForPathname } from "../utils/seo";
import type { UiLang } from "../utils/seo";
import { buildPersonAndProfessionalService } from "../utils/jsonLd";

export interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	ogType?: "website" | "article";
	noindex?: boolean;
	keywords?: string[];
	/** Full canonical URL; defaults to current path on SITE_URL */
	canonical?: string;
	articlePublishedTime?: string;
	articleModifiedTime?: string;
	articleSection?: string;
	articleTags?: string[];
	/** Extra schema.org nodes merged into @graph (e.g. BlogPosting, Service) */
	jsonLdExtra?: Record<string, unknown>[];
}

const {
	title: titleProp,
	description: descriptionProp,
	ogImage,
	ogType = "website",
	noindex = false,
	keywords = [],
	canonical: canonicalProp,
	articlePublishedTime,
	articleModifiedTime,
	articleSection,
	articleTags,
	jsonLdExtra = [],
} = Astro.props;

const lang = getLangFromUrl(Astro.url) as UiLang;
const t = useTranslations(lang);

const homeSlug = `/${lang || ""}`;
const blogSlug = `/${lang || ""}/blog`;
const contactSlug = `/${lang || ""}/contact`;

const pathname =
	Astro.url.pathname.endsWith("/") && Astro.url.pathname !== "/"
		? Astro.url.pathname.slice(0, -1)
		: Astro.url.pathname;
const canonical =
	canonicalProp ?? absoluteUrl(pathname === "" ? "/en" : pathname);

const pageTitle = titleProp ?? t("seo.site.title");
const metaDescription = descriptionProp ?? t("seo.site.description");

const defaultOg = "/about/lucabertelli.jpeg";
const ogImageAbsolute = absoluteUrl(ogImage ?? defaultOg);

const alternates = alternatesForPathname(pathname);
const languageAlternates = alternates
	? [
			{ href: alternates.en, hrefLang: "en" },
			{ href: alternates.it, hrefLang: "it" },
			{ href: alternates.xDefault, hrefLang: "x-default" },
		]
	: undefined;

const baseGraph = buildPersonAndProfessionalService(lang);
const graph = [...baseGraph, ...jsonLdExtra];
const jsonLdPayload = JSON.stringify({
	"@context": "https://schema.org",
	"@graph": graph,
});
---

<!-- @ts-nocheck - false positives on media HTML attribute -->
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta http-equiv="X-UA-Compatible" content="IE=edge" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<!-- Critical CSS - render-blocking on purpose -->
		<link rel="stylesheet" href="/styles/critical.css" />
		<link rel="stylesheet" href="/styles/fonts.css" />

		<!-- Preconnect for external font provider -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<!-- Non-blocking Google Fonts CSS (swap avoids text invisibility) -->
		<link
			rel="preload"
			href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Plus+Jakarta+Sans:wght@400;600;700&display=swap"
			as="style"
			onload="this.onload=null;this.rel='stylesheet'"
		/>
		<noscript>
			<link
				rel="stylesheet"
				href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Plus+Jakarta+Sans:wght@400;600;700&display=swap"
			/>
		</noscript>

		<!-- Preload local CSS resources for early discovery -->
		<link rel="preload" href="/styles/bootstrap.min.css" as="style" />
		<link rel="preload" href="/styles/all.min.css" as="style" />
		<link rel="preload" href="/styles/master.css" as="style" />
		<link rel="preload" href="/styles/style.css" as="style" />

		<!-- Core framework CSS remains blocking -->
		<link rel="stylesheet" href="/styles/bootstrap.min.css" />
		<link rel="stylesheet" href="/styles/all.min.css" media="print" onload="this.media='all'" />
		<link rel="stylesheet" href="/styles/master.css" media="print" onload="this.media='all'" />
		<link rel="stylesheet" href="/styles/style.css" media="print" onload="this.media='all'" />
		<noscript>
			<link rel="stylesheet" href="/styles/all.min.css" />
			<link rel="stylesheet" href="/styles/master.css" />
			<link rel="stylesheet" href="/styles/style.css" />
		</noscript>
		<SEO
			title={pageTitle}
			titleDefault={t("seo.site.title")}
			description={metaDescription}
			canonical={canonical}
			noindex={noindex}
			languageAlternates={languageAlternates}
			openGraph={{
				basic: {
					title: pageTitle,
					type: ogType,
					image: ogImageAbsolute,
					url: canonical,
				},
				optional: {
					description: metaDescription,
					locale: lang === "it" ? "it_IT" : "en_US",
					siteName: "Luca Bertelli Consulting",
				},
				image: {
					alt: "Luca Bertelli",
				},
				article:
					ogType === "article" && articlePublishedTime
						? {
								publishedTime: articlePublishedTime,
								modifiedTime: articleModifiedTime ?? articlePublishedTime,
								section: articleSection,
								tags: articleTags,
							}
						: undefined,
			}}
			twitter={{
				card: "summary_large_image",
				title: pageTitle,
				description: metaDescription,
				image: ogImageAbsolute,
				imageAlt: pageTitle,
			}}
			extend={{
				meta:
					keywords.length > 0
						? [{ name: "keywords", content: keywords.join(", ") }]
						: [],
			}}
		/>

		<!-- Fav Icon -->
		<link rel="icon" type="image/x-icon" href="/favicon.svg" />

		<script type="application/ld+json" set:html={jsonLdPayload} />

		<style is:inline>
			.skip-to-content {
				position: absolute;
				left: -9999px;
				top: 0;
				z-index: 100000;
				padding: 0.65rem 1rem;
				font-weight: 700;
				font-size: 0.95rem;
				text-decoration: none;
				background: #ffe24c;
				color: #1c1d20;
				border-radius: 6px;
				box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
			}
			.skip-to-content:focus {
				left: 1rem;
				top: 1rem;
				position: fixed;
				outline: 2px solid #1c1d20;
				outline-offset: 2px;
			}
			.offcanvas__menu-list ul {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.offcanvas__menu-list li + li {
				margin-top: 0.75rem;
			}
			.offcanvas__menu-list a {
				display: inline-block;
				font-size: 1.125rem;
				font-weight: 600;
			}
			.body-overlay {
				position: fixed;
				inset: 0;
				background: rgba(0, 0, 0, 0.45);
				opacity: 0;
				visibility: hidden;
				transition: opacity 0.2s ease;
				z-index: 1040;
			}
			.body-overlay.show {
				opacity: 1;
				visibility: visible;
			}
			body.offcanvas-open {
				overflow: hidden;
			}
		</style>
	</head>

	<body class="font-heading-estedad">
		<a class="skip-to-content" href="#main-content">{t("a11y.skipToContent")}</a>

		<div class="body-overlay"></div>

		<div id="smooth-wrapper">
			<div id="smooth-content">
				<div class="body-wrapper">
					<!-- Header area start -->
					<Header />
					<!-- Header area end -->
					<main id="main-content" tabindex="-1">
						<slot />
					</main>

					<!-- Footer section start -->
					<Footer />
					<!-- Footer section end -->
				</div>
			</div>

			<!-- Offcanves start -->
			<div class="offcanvas__area">
				<div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasOne">
					<button class="offcanvas__close" type="button" data-offcanvas-close
						><i class="fa-solid fa-xmark"></i></button
					>
					<div class="offcanvas__body">
						<div class="offcanvas__logo">
							<a href={homeSlug}>
								<img src="/logo.png" alt="" />
							</a>
						</div>

						<div class="offcanvas__menu-area">
							<nav class="offcanvas__menu-list" aria-label="Mobile menu">
								<ul>
									<li><a href={homeSlug}>{t("nav.home")}</a></li>
									<li><a href={blogSlug}>{t("nav.blog")}</a></li>
									<li><a href={contactSlug}>{t("nav.contact")}</a></li>
								</ul>
							</nav>
						</div>
						<div class="offcanvas__media">
							<h2 class="offcanvas__title">{t("footer.follow")}</h2>
							<ul>
								<li>
									<a
										href="https://github.com/banshee86vr"
										target="_blank"
										rel="noopener noreferrer"
										aria-label={t("a11y.social.github")}
										><i class="fa-brands fa-github" aria-hidden="true"></i></a
									>
								</li>
								<li>
									<a
										href="https://www.linkedin.com/in/luca-bertelli-a1413b77"
										target="_blank"
										rel="noopener noreferrer"
										aria-label={t("a11y.social.linkedin")}
										><i class="fa-brands fa-linkedin" aria-hidden="true"></i></a
									>
								</li>
								<li>
									<a
										href="https://medium.com/@bertelli.luca"
										target="_blank"
										rel="noopener noreferrer"
										aria-label={t("a11y.social.medium")}
										><i class="fa-brands fa-medium" aria-hidden="true"></i></a
									>
								</li>
								<li>
									<a
										href="https://www.credly.com/users/luca-bertelli"
										target="_blank"
										rel="noopener noreferrer"
										aria-label={t("a11y.social.credly")}
										><i class="fa-solid fa-c" aria-hidden="true"></i></a
									>
								</li>
							</ul>
						</div>
					</div>
				</div>
			</div>
			<!-- Offcanves end -->
		</div>

		<!-- Cookie Banner - Fixed floating box at bottom of viewport -->
		<CookieBanner />

		<!-- Lightweight offcanvas controller replaces full Bootstrap JS bundle -->
		<script is:inline>
			(() => {
				const openBtn = document.getElementById("open_offcanvas");
				const panel = document.getElementById("offcanvasOne");
				const closeBtn = panel?.querySelector("[data-offcanvas-close]");
				const overlay = document.querySelector(".body-overlay");

				if (!openBtn || !panel || !closeBtn || !overlay) return;

				const closeOffcanvas = () => {
					panel.classList.remove("show");
					overlay.classList.remove("show");
					document.body.classList.remove("offcanvas-open");
					openBtn.setAttribute("aria-expanded", "false");
				};

				const openOffcanvas = () => {
					panel.classList.add("show");
					overlay.classList.add("show");
					document.body.classList.add("offcanvas-open");
					openBtn.setAttribute("aria-expanded", "true");
				};

				openBtn.addEventListener("click", openOffcanvas);
				closeBtn.addEventListener("click", closeOffcanvas);
				overlay.addEventListener("click", closeOffcanvas);
				document.addEventListener("keydown", (event) => {
					if (event.key === "Escape") closeOffcanvas();
				});
			})();
		</script>
	</body>
</html>

---
import BaseLayout from "../../layouts/Common.astro";
import Experience from "../../components/Experience.astro";
import Certifications from "../../components/Certifications.astro";
import Services from "../../components/Services.astro";
import Tickets from "../../components/Tickets.astro";
import { getCollection } from "astro:content";

import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { buildCertificationCredentials, buildServiceOffers } from "../../utils/jsonLd";
import type { UiLang } from "../../utils/seo";

export const prerender = true;

export async function getStaticPaths() {
	return [{ params: { lang: "en" } }, { params: { lang: "it" } }];
}

const lang = getLangFromUrl(Astro.url) as UiLang;
const t = useTranslations(lang);

const serviceOffers = [
	{ name: t("index.services.1.title"), description: t("index.services.1.text") },
	{ name: t("index.services.2.title"), description: t("index.services.2.text") },
	{ name: t("index.services.3.title"), description: t("index.services.3.text") },
	{ name: t("index.services.4.title"), description: t("index.services.4.text") },
	{ name: t("index.services.5.title"), description: t("index.services.5.text") },
];
const servicesJsonLd = buildServiceOffers(serviceOffers, lang);
const certifications = await getCollection("certifications");
const credentialsJsonLd = buildCertificationCredentials(
	certifications.map((entry) => ({
		title: entry.data.title,
		url: entry.data.url,
		issueDate: entry.data.issueDate,
	})),
);
const heroRoles = [
	t("index.hero.role.engineer"),
	t("index.hero.role.advisor"),
	t("index.hero.role.consultant"),
	t("index.hero.role.developer"),
];
---

<BaseLayout
	title={t("seo.home.title")}
	description={t("seo.home.description")}
	ogImage="/about/lucabertelli.jpeg"
	keywords={[
		"Luca Bertelli",
		"LB Consulting",
		"lb.consulting",
		"Cloud Native consultant",
		"Kubernetes certified",
		"HashiCorp certified",
		"Terraform certified",
		"GitLab certified",
		"Kong certified",
	]}
	jsonLdExtra={[...servicesJsonLd, ...credentialsJsonLd]}
>
  <!-- Hero area start -->
  <section class="about__hero plr-50 pt-100 pb-120">
    <div class="container">
      <div class="row">
        <div class="col-lg-4">
          <div
            class="about__experience-img cf_img"
            style="align-items:unset"
          >
            <picture>
              <source
                type="image/webp"
                srcset="/about/lucabertelli.jpeg?format=webp&w=360 360w, /about/lucabertelli.jpeg?format=webp&w=540 540w, /about/lucabertelli.jpeg?format=webp&w=720 720w, /about/lucabertelli.jpeg?format=webp&w=960 960w"
                sizes="(max-width: 575px) 90vw, (max-width: 991px) 400px, 33vw"
              />
              <source
                srcset="/about/lucabertelli.jpeg?w=360 360w, /about/lucabertelli.jpeg?w=540 540w, /about/lucabertelli.jpeg?w=720 720w, /about/lucabertelli.jpeg?w=960 960w"
                sizes="(max-width: 575px) 90vw, (max-width: 991px) 400px, 33vw"
              />
              <img
                src="/about/lucabertelli.jpeg?w=540"
                srcset="/about/lucabertelli.jpeg?w=360 360w, /about/lucabertelli.jpeg?w=540 540w, /about/lucabertelli.jpeg?w=720 720w, /about/lucabertelli.jpeg?w=960 960w"
                sizes="(max-width: 575px) 90vw, (max-width: 991px) 400px, 33vw"
                alt="Luca Bertelli"
                width="1000"
                height="1333"
                fetchpriority="high"
                decoding="async"
              />
            </picture>
          </div>
        </div>
        <div class="col-lg-8">
          <div class="about__hero-right">
            <p class="lb__hero-subtitle">{t('index.hi')}</p>
            <h1
              class="lb__hero-title"
            >
              {t('index.hero.cloudNative')} <br />
              <span
                class="lb__hero-role-viewport"
                data-lb-hero-role
                data-lb-hero-roles={heroRoles.join("|")}
              >
                <span class="lb__hero-role-text">{heroRoles[0]}</span>
              </span>
            </h1>
            <div class="cf_text">
              <p style="max-width:100%">{t('index.bio')}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- Hero area end -->

  <Experience />

  <Services />

  <Certifications />

  <Tickets />
</BaseLayout>

<script is:inline>
  (() => {
    const roleViewport = document.querySelector("[data-lb-hero-role]");
    if (!roleViewport) return;
    if (roleViewport.getAttribute("data-lb-hero-init") === "true") return;
    roleViewport.setAttribute("data-lb-hero-init", "true");

    const roleText = roleViewport.querySelector(".lb__hero-role-text");
    if (!roleText) return;

    const rawRoles = roleViewport.getAttribute("data-lb-hero-roles");
    if (!rawRoles) return;

    const roles = rawRoles.split("|").map((item) => item.trim()).filter(Boolean);
    if (roles.length < 2) return;

    const TYPING_SPEED_MS = 95;
    const DELETING_SPEED_MS = 55;
    const HOLD_TYPED_MS = 1200;
    const HOLD_EMPTY_MS = 250;

    let roleIndex = 0;
    let charIndex = 0;
    let isDeleting = false;

    roleText.textContent = "";

    const tick = () => {
      const currentRole = roles[roleIndex];

      if (!isDeleting) {
        charIndex += 1;
        roleText.textContent = currentRole.slice(0, charIndex);

        if (charIndex >= currentRole.length) {
          isDeleting = true;
          window.setTimeout(tick, HOLD_TYPED_MS);
          return;
        }

        window.setTimeout(tick, TYPING_SPEED_MS);
        return;
      }

      charIndex -= 1;
      roleText.textContent = currentRole.slice(0, Math.max(0, charIndex));

      if (charIndex <= 0) {
        isDeleting = false;
        roleIndex = (roleIndex + 1) % roles.length;
        window.setTimeout(tick, HOLD_EMPTY_MS);
        return;
      }

      window.setTimeout(tick, DELETING_SPEED_MS);
    };

    tick();
  })();
</script>

<style>
  .about__hero .row {
    display: flex;
    align-items: stretch;
  }

  .about__hero .col-lg-4 {
    display: flex;
    flex-direction: column;
  }

  .about__hero .col-lg-8 {
    display: flex;
    flex-direction: column;
  }

  .about__experience-img {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .about__experience-img picture {
    width: 100%;
    height: 100%;
    display: flex;
    flex: 1;
  }

  .about__experience-img img {
    width: 100% !important;
    height: 100% !important;
    max-width: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .about__hero-right {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-left: 40px;
    flex: 1;
  }

  .lb__hero-title {
    font-size: 50px;
  }

  .lb__hero-role-viewport {
    display: inline-block;
    min-width: 11ch;
    vertical-align: bottom;
  }

  .lb__hero-role-text {
    display: inline-block;
    white-space: nowrap;
    font-variant-ligatures: none;
    will-change: contents;
  }

  @media only screen and (max-width: 991px) {
    .about__hero .row {
      flex-direction: column;
    }

    .about__experience-img {
      height: auto;
      max-width: 400px;
      margin: 0 auto;
    }

    .about__experience-img picture {
      height: auto;
    }

    .about__experience-img img {
      height: auto !important;
      object-fit: contain;
    }

    .about__hero-right {
      padding-left: 0;
      padding-top: 40px;
    }

    .lb__hero-title {
      font-size: 38px;
    }
  }

  @media only screen and (max-width: 575px) {
    .lb__hero-title {
      font-size: 32px;
    }
  }

</style>

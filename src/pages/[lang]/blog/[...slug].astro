---
import { render } from "astro:content";
import PostLayout from "../../../layouts/Post.astro";
import { getBlogPosts } from "../../../content/config";
import type { BlogPost } from "../../../content/config";

const { lang, slug } = Astro.params;

const posts = await getBlogPosts();
const page = posts.find(
  (p) => p.blog_slug === slug && (p.data.lang === lang || (!p.data.lang && lang === "en")),
) as BlogPost | undefined;

if (!page) {
  return Astro.redirect(`/${lang || "en"}/blog/`);
}

const { title, image, subtitle, date, category, tags } = page.data;
const resolvedLang =
	page.data.lang === "en" || page.data.lang === "it" ? page.data.lang : "en";

const { Content } = await render(
	page as unknown as import("astro:content").CollectionEntry<"blog">,
);
---

<PostLayout
  title={title}
  image={image}
  subtitle={subtitle}
  date={new Date(date)}
  category={category}
  tags={tags}
  lang={resolvedLang}
>
  <Content />
</PostLayout>